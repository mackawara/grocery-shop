# Application
APP_ENV=local
PORT=4000
NGROK_DOMAIN= # Required when APP_ENV=local

# Redis
REDIS_HOST=localhost
REDIS_HOST_PORT=6379
REDIS_CONNECT_TIMEOUT=90000

# MongoDB
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_HOST=

# WhatsApp
WHATSAPP_WEBHOOK_VERIFICATION_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_SYSTEM_TOKEN=

# Authentik OIDC (BFF login)
# Issuer URL from the Authentik provider (note the trailing slash):
#   https://auth.ventatech.duckdns.org/application/o/<app-slug>/
AUTHENTIK_ISSUER=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
# Defaults to ${PUBLIC_BASE_URL}/auth/callback — must match the provider's
# Redirect URI exactly. Set explicitly only if the callback host differs.
AUTH_REDIRECT_URI=
# SPA origin: allowed through CORS and redirected to after login/logout.
DASHBOARD_URL=
AUTHENTIK_POST_LOGOUT_REDIRECT= # defaults to DASHBOARD_URL
# Long random string; rotate to invalidate all sessions.
SESSION_SECRET=
SESSION_COOKIE_NAME=gs.sid
